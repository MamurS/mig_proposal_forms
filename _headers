# Cloudflare Pages security headers
# Place this file at the root of your repo. Cloudflare reads it on every deploy
# and applies the headers to matching paths.

# Apply to all routes
/*
  # === Content Security Policy ===
  # Restricts what the browser will load and execute.
  #   default-src 'self'        — only same-origin by default
  #   script-src                — same-origin + the three CDNs we actually use
  #   style-src                 — same-origin + Google Fonts CSS + inline styles (form uses them heavily)
  #   font-src                  — Google Fonts hosts only
  #   img-src                   — same-origin + data: URIs (we embed PDFs/logos as base64)
  #   connect-src               — same-origin + your Supabase project (REPLACE THE URL BELOW)
  #   frame-ancestors 'none'    — prevents this page from being iframed by another site (clickjacking)
  #   base-uri 'self'           — prevents <base> tag hijacking
  #   form-action 'self'        — form submissions can only target same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://*.supabase.co https://*.supabase.in; frame-ancestors 'self'; base-uri 'self'; form-action 'self'

  # === Clickjacking ===
  # Belt-and-suspenders with the CSP frame-ancestors above. SAMEORIGIN (not
  # DENY): the admin Submissions page embeds /proposal/?view=… in an iframe —
  # same-origin framing must be allowed; other sites still cannot frame us.
  X-Frame-Options: SAMEORIGIN

  # === MIME sniffing ===
  # Prevents the browser from guessing content types (e.g. running text/plain as JS)
  X-Content-Type-Options: nosniff

  # === Referrer policy ===
  # Don't leak the full URL when users click external links
  Referrer-Policy: strict-origin-when-cross-origin

  # === Permissions policy ===
  # Disable browser features we don't use. Reduces attack surface.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()

  # === HSTS ===
  # Tells the browser to always use HTTPS for this domain.
  # max-age = 1 year. Only enable preload after you're sure the site is stable.
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# === Caching ===
# HTML stays default (revalidated each deploy); local JS gets a short browser
# cache so page-to-page navigation doesn't re-fetch it, while deploys still
# propagate within minutes. The wording bundles change rarely → longer cache.
# The app scripts must always revalidate — without a Cache-Control header,
# browsers cache them heuristically and keep running stale code for days
# (seen live: fresh HTML + week-old policy_app.js). Etag makes this cheap.
/admin/policy/policy_app.js
  Cache-Control: public, max-age=0, must-revalidate

/admin/quote/quote_docx.js
  Cache-Control: public, max-age=0, must-revalidate

/shared/*
  Cache-Control: public, max-age=600

/config.js
  Cache-Control: public, max-age=600

/admin/cyber/policy/wording_content.js
  Cache-Control: public, max-age=3600

/admin/crime/policy/wording_content.js
  Cache-Control: public, max-age=3600
